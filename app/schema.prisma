datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  email    String? @unique
  username String? @unique
  isAdmin  Boolean @default(false)

  company   Company? @relation(fields: [companyId], references: [id])
  companyId String?
  role      String   @default("client")
  fullName  String?
}

model Company {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name         String
  legalName    String?
  email        String?
  phone        String?
  address      String?
  city         String?
  province     String  @default("QC")
  postalCode   String?
  country      String  @default("Canada")
  website      String?
  neq          String?
  taxNumberGst String?
  taxNumberQst String?
  currency     String  @default("CAD")
  locale       String  @default("fr-CA")

  // Branding (used in generated PDFs / public docs).
  brandLogoKey      String?
  brandPrimaryColor String? @default("#0E0E0E")
  brandAccentColor  String? @default("#D4A24C")
  brandTextColor    String? @default("#1A1A1A")
  brandTagline      String?

  users           User[]
  clients         Client[]
  projects        Project[]
  documents       Document[]
  payments        Payment[]
  meetings        Meeting[]
  automations     Automation[]
  priceItems      PriceItem[]
  priceCategories PriceCategory[]
}

model Client {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  city        String?
  province    String  @default("QC")
  postalCode  String?
  notes       String?
  status      String  @default("actif")

  projects  Project[]
  documents Document[]
  meetings  Meeting[]
}

model Project {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId String?

  name        String
  description String?
  status      String    @default("en_cours")
  startDate   DateTime?
  dueDate     DateTime?
  budget      Float?

  documents Document[]
}

model Document {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId String?

  // 'quote' | 'invoice' — same record can be promoted from quote to invoice.
  type          String    @default("quote")
  number        String
  title         String?
  description   String?
  status        String    @default("actif")
  issueDate     DateTime  @default(now())
  validUntil    DateTime?
  dueDate       DateTime?
  discountType  String    @default("percent")
  discountValue Float     @default(0)
  subtotal      Float     @default(0)
  taxGst        Float     @default(0)
  taxQst        Float     @default(0)
  total         Float     @default(0)
  amountPaid    Float     @default(0)
  notes         String?

  items    DocumentItem[]
  payments Payment[]

  @@unique([companyId, number])
}

model DocumentItem {
  id         String   @id @default(uuid())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String

  description String
  note        String?
  quantity    Float   @default(1)
  unitPrice   Float   @default(0)
  amount      Float   @default(0)
}

model Payment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String

  amount    Float
  method    String   @default("virement")
  paidAt    DateTime @default(now())
  reference String?
  notes     String?
}

model Meeting {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId String?

  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime?
  location    String?
  meetingUrl  String?
  status      String    @default("prevue")
}

model PriceItem {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  code        String?
  name        String
  description String?
  category    String?
  unit        String  @default("unite")
  unitPrice   Float   @default(0)
  isActive    Boolean @default(true)
}

model PriceCategory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  name String

  @@unique([companyId, name])
}

model Automation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String

  name        String
  description String?
  trigger     String
  action      String
  isActive    Boolean @default(true)
  config      Json?
}
