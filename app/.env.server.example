# Gestia — variables d'environnement (serveur)

# Base de données
# Si vous utilisez `wasp start db` (recommandé en local), laissez DATABASE_URL commenté.
# Wasp configurera automatiquement la connexion à la base PostgreSQL Docker.
# DATABASE_URL=postgresql://user:password@localhost:5432/gestia

# Comptes administrateurs
# Liste séparée par des virgules. Toute personne s'inscrivant avec un de ces courriels
# obtient automatiquement le rôle administrateur.
ADMIN_EMAILS=admin@gestia.ca

# Désactiver les nouvelles inscriptions (protège aussi l'API backend)
# DISABLE_SIGNUP=true
